rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Par défaut, on protège les données.
    // L'utilisateur doit être connecté pour lire ou écrire dans n'importe quelle collection.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Exemples plus stricts si besoin plus tard :
    // match /tasks/{taskId} {
    //   allow read, write: if request.auth != null;
    // }
    // match /family_chat/{messageId} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
